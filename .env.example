DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Public sharing protection. Default: 60 AI requests per IP per hour.
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=60

# Optional pronunciation providers. Leave blank to use free sources and browser speech fallback.
MERRIAM_WEBSTER_API_KEY=
WORDNIK_API_KEY=
FORVO_API_KEY=

PORT=8787
